" => tabs and indenting
"""""""""""""""""""""""""""""""""""""""""""""""""""""""""""""""
" number of spaces to use for autoindenting
set shiftwidth=2
set tabstop=2

" enable emmet in php files
imap <tab>o <C-y>,

iabbr php, <?php<Cr><Cr>?>

syntax enable
